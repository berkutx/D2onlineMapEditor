{
  "name": "@d2/asset-manifest",
  "version": "0.1.0",
  "description": "Contract B: asset manifest + PixiJS-compatible spritesheet/animation schema",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema.json": "./gen/asset-manifest.schema.json",
    "./spritesheet.schema.json": "./gen/spritesheet.schema.json"
  },
  "files": ["dist", "gen"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "gen": "tsx scripts/gen.ts",
    "clean": "rimraf dist gen"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "zod-to-json-schema": "^3.23.5",
    "tsx": "^4.19.2"
  }
}
