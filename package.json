{
  "name": "d2-web-editor",
  "version": "0.0.0",
  "private": true,
  "description": "Browser port of the Disciples 2 map editor (Vue + Element Plus + PixiJS + Node/socket.io)",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "gen": "turbo run gen",
    "build:tsc": "tsc -b",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "rimraf": "^6.0.1"
  }
}
